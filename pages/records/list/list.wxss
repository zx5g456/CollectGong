page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f6f7f9;
}

.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.page {
  min-height: 100%;
  padding: 48rpx 32rpx calc(56rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.title {
  color: #17233d;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.3;
}

.desc {
  margin-top: 16rpx;
  color: #697386;
  font-size: 28rpx;
  line-height: 1.6;
}

.record-list {
  margin-top: 36rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.record-group {
  border-radius: 8px;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(20, 31, 51, 0.06);
  overflow: hidden;
}

.empty-card {
  padding: 48rpx 32rpx;
  border-radius: 8px;
  background: #ffffff;
  color: #697386;
  font-size: 28rpx;
  text-align: center;
  box-shadow: 0 12rpx 36rpx rgba(20, 31, 51, 0.06);
}

.record-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  background: #ffffff;
}

.record-name {
  color: #17233d;
  font-size: 32rpx;
  font-weight: 600;
}

.record-meta {
  margin-top: 12rpx;
  color: #697386;
  font-size: 25rpx;
}

.record-time {
  margin-left: 24rpx;
  color: #4f7df3;
  font-size: 24rpx;
  text-align: right;
}

.submission-list {
  padding: 0 32rpx 32rpx;
}

.export-button {
  height: 80rpx;
  margin: 0 0 24rpx;
  border-radius: 8px;
  background: #4f7df3;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 80rpx;
}

.export-button::after {
  border: 0;
}

.empty-text {
  padding-top: 20rpx;
  color: #697386;
  font-size: 26rpx;
}

.submission-card {
  padding: 24rpx 0;
  border-top: 1rpx solid #e7eaf0;
}

.submission-time {
  color: #697386;
  font-size: 24rpx;
}

.submission-row {
  margin-top: 14rpx;
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  color: #17233d;
  font-size: 27rpx;
}

.submission-key {
  color: #697386;
}

.submission-value {
  flex: 1;
  text-align: right;
  word-break: break-all;
}
