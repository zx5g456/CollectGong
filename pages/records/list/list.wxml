<navigation-bar title="收集信息" back="{{true}}" color="black" background="#FFF"></navigation-bar>
<scroll-view class="scrollarea" scroll-y type="list">
  <view class="page">
    <view class="title">按模板查看信息</view>
    <view class="desc">每个模板下展示填写情况、填写人相关信息，并支持按时间排序。</view>

    <view class="record-list">
      <view wx:for="{{groups}}" wx:key="id" class="record-group">
        <view class="record-card" bindtap="onOpenGroup" data-id="{{item.id}}">
          <view>
            <view class="record-name">{{item.name}}</view>
            <view class="record-meta">共 {{item.count}} 条填写</view>
          </view>
          <view class="record-time">{{item.latestAt}}</view>
        </view>

        <view wx:if="{{activeTemplateId === item.id}}" class="submission-list">
          <view wx:if="{{loadingRecords}}" class="empty-text">加载中...</view>
          <view wx:elif="{{!records.length}}" class="empty-text">暂无提交记录</view>
          <block wx:else>
            <view wx:for="{{records}}" wx:key="id" wx:for-item="record" class="submission-card">
              <view class="submission-time">{{record.createdAt}}</view>
              <view wx:for="{{record.values}}" wx:key="key" wx:for-item="valueItem" class="submission-row">
                <text class="submission-key">{{valueItem.label}}</text>
                <text class="submission-value">{{valueItem.value}}</text>
              </view>
            </view>
          </block>
        </view>
      </view>
    </view>
  </view>
</scroll-view>
