/**index.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f6f7f9;
}

.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.login-page {
  min-height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx 48rpx calc(64rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.login-panel {
  width: 100%;
  max-width: 640rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 44rpx;
  box-sizing: border-box;
  border-radius: 8px;
  background: #ffffff;
  box-shadow: 0 16rpx 48rpx rgba(20, 31, 51, 0.08);
}

.wechat-mark {
  width: 112rpx;
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #07c160;
  color: #ffffff;
  font-size: 48rpx;
  font-weight: 600;
}

.login-title {
  margin-top: 40rpx;
  color: #17233d;
  font-size: 40rpx;
  font-weight: 600;
  line-height: 1.3;
}

.login-desc {
  margin-top: 20rpx;
  color: #697386;
  font-size: 28rpx;
  line-height: 1.6;
  text-align: center;
}

.wechat-login-button {
  width: 100%;
  height: 96rpx;
  margin-top: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  background: #07c160;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
}

.wechat-login-button::after {
  border: 0;
}

.wechat-login-button[disabled] {
  background: #8bdcac;
  color: rgba(255, 255, 255, 0.9);
}

.dashboard-page {
  min-height: 100%;
  padding: 48rpx 32rpx calc(56rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.dashboard-header {
  padding: 12rpx 8rpx 36rpx;
}

.dashboard-title {
  color: #17233d;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.3;
}

.dashboard-desc {
  margin-top: 16rpx;
  color: #697386;
  font-size: 28rpx;
  line-height: 1.6;
}

.action-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.action-card {
  min-height: 156rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  box-sizing: border-box;
  border-radius: 8px;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(20, 31, 51, 0.06);
}

.action-card:active {
  background: #f9fafc;
}

.action-content {
  flex: 1;
  min-width: 0;
}

.action-title {
  color: #17233d;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.35;
}

.action-desc {
  margin-top: 12rpx;
  color: #697386;
  font-size: 26rpx;
  line-height: 1.5;
}

.action-arrow {
  flex: none;
  margin-left: 28rpx;
  color: #4f7df3;
  font-size: 52rpx;
  line-height: 1;
}
