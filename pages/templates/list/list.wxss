page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f6f7f9;
}

.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.page {
  min-height: 100%;
  padding: 48rpx 32rpx calc(56rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.title {
  color: #17233d;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.3;
}

.desc {
  margin-top: 16rpx;
  color: #697386;
  font-size: 28rpx;
  line-height: 1.6;
}

.template-list {
  margin-top: 36rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.template-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-radius: 8px;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(20, 31, 51, 0.06);
}

.template-info {
  flex: 1;
  min-width: 0;
}

.template-name {
  color: #17233d;
  font-size: 32rpx;
  font-weight: 600;
}

.template-meta {
  margin-top: 12rpx;
  color: #697386;
  font-size: 25rpx;
  line-height: 1.5;
}

.share-button {
  width: 132rpx;
  height: 72rpx;
  margin-left: 24rpx;
  border-radius: 8px;
  background: #07c160;
  color: #ffffff;
  font-size: 28rpx;
}

.share-button::after {
  border: 0;
}
