page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f6f7f9;
}

.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.page {
  min-height: 100%;
  padding: 48rpx 32rpx calc(56rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.title {
  color: #17233d;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.3;
}

.desc {
  margin-top: 16rpx;
  color: #697386;
  font-size: 28rpx;
  line-height: 1.6;
}

.empty-card,
.form-card {
  margin-top: 36rpx;
  padding: 32rpx;
  border-radius: 8px;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(20, 31, 51, 0.06);
}

.empty-card {
  color: #697386;
  font-size: 28rpx;
  text-align: center;
}

.field-item + .field-item {
  margin-top: 56rpx;
}

.field-title {
  color: #111111;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.4;
}

.field-desc {
  margin-top: 28rpx;
  color: #111111;
  font-size: 30rpx;
  line-height: 1.6;
}

.field-input {
  height: 88rpx;
  margin-top: 40rpx;
  padding: 0;
  border-bottom: 1rpx solid #9b9b9b;
  color: #111111;
  font-size: 36rpx;
}

.submit-button {
  height: 96rpx;
  margin-top: 64rpx;
  border-radius: 8px;
  background: #07c160;
  color: #ffffff;
  font-size: 32rpx;
}

.submit-button::after {
  border: 0;
}
