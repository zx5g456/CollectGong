page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f6f7f9;
}

.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.page {
  min-height: 100%;
  padding: 48rpx 32rpx calc(56rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.title {
  color: #17233d;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.3;
}

.desc {
  margin-top: 16rpx;
  color: #697386;
  font-size: 28rpx;
  line-height: 1.6;
}

.form-section,
.preview-section {
  margin-top: 40rpx;
  padding: 28rpx;
  border-radius: 8px;
  background: #ffffff;
}

.section-title {
  color: #17233d;
  font-size: 30rpx;
  font-weight: 600;
}

.text-input,
.picker-value {
  min-height: 88rpx;
  margin-top: 20rpx;
  padding: 24rpx;
  box-sizing: border-box;
  border-radius: 8px;
  background: #f6f7f9;
  color: #17233d;
  font-size: 28rpx;
}

.field-editor {
  margin-top: 28rpx;
  padding: 28rpx;
  border: 1rpx solid #e7eaf0;
  border-radius: 8px;
}

.field-editor-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.field-editor-title {
  color: #17233d;
  font-size: 30rpx;
  font-weight: 600;
}

.ghost-button {
  width: 112rpx;
  height: 64rpx;
  margin: 0;
  border-radius: 8px;
  background: #fff1f0;
  color: #d93026;
  font-size: 26rpx;
  line-height: 64rpx;
}

.ghost-button::after {
  border: 0;
}

.control {
  margin-top: 24rpx;
}

.control-label {
  color: #697386;
  font-size: 25rpx;
}

.control-row {
  display: flex;
  gap: 20rpx;
}

.type-control {
  flex: 1;
}

.required-control {
  width: 180rpx;
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #697386;
  font-size: 25rpx;
}

.secondary-button {
  height: 88rpx;
  margin-top: 28rpx;
  border-radius: 8px;
  background: #eef3ff;
  color: #4f7df3;
  font-size: 30rpx;
}

.secondary-button::after {
  border: 0;
}

.preview-card {
  margin-top: 24rpx;
  padding: 32rpx;
  border-radius: 8px;
  background: #f7f7f7;
}

.preview-field + .preview-field {
  margin-top: 56rpx;
}

.preview-title {
  color: #111111;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.4;
}

.preview-desc {
  margin-top: 34rpx;
  color: #111111;
  font-size: 31rpx;
  line-height: 1.6;
}

.preview-input {
  height: 88rpx;
  margin-top: 48rpx;
  padding: 0;
  border-bottom: 1rpx solid #9b9b9b;
  color: #111111;
  font-size: 40rpx;
}

.primary-button {
  height: 96rpx;
  margin-top: 40rpx;
  border-radius: 8px;
  background: #4f7df3;
  color: #ffffff;
  font-size: 32rpx;
}

.primary-button::after {
  border: 0;
}
